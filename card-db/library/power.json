  {
    "id": 100764,
    "_name": "Foresee",
    "url": "https://static.krcg.org/card/foresee.jpg",
    "types": [
      "Power"
    ],
    "disciplines": [
      "viz"
    ],
    "card_text": "[COMBAT] [1 CONVICTION] Only usable before range is determined on the first round of combat resulting from a block. Look at the opposing minion's controller's hand. You may then choose to cancel combat. If you do, and this imbued was blocking, the action continues as if unblocked.",
    "_set": "NoR:R",
    "sets": {
      "Nights of Reckoning": [
        {
          "release_date": "2006-04-10",
          "rarity": "Rare"
        }
      ]
    },
    "scans": {
      "Nights of Reckoning": "https://static.krcg.org/card/set/nights-of-reckoning/foresee.jpg"
    },
    "artists": [
      "Eric Lofgren"
    ],
    "ordered_sets": [
      "Nights of Reckoning"
    ],
    "legality": "2006-04-10",
    "rulings": [
      {
        "text": "If the action continues \"as if unblocked\", all action modifiers and reaction cards are still in effect, even those pertaining to a successful block. [RTR 19941109] [ANK 20190116]",
        "references": [
          {
            "text": "[RTR 19941109]",
            "label": "RTR 19941109",
            "url": "https://groups.google.com/d/msg/rec.games.deckmaster/_6CXoKTSLnw/FdG67-3HEAQJ"
          },
          {
            "text": "[ANK 20190116]",
            "label": "ANK 20190116",
            "url": "https://www.vekn.net/forum/rules-questions/77302-strike-combat-ends-continue-with-the-action#92916"
          }
        ],
        "group": "Action continue as if unblocked"
      },
      {
        "text": "If the action continues \"as if unblocked\", any Methuselahs that have declined to block before do not get another opportunity to block. [ANK 20190116]",
        "references": [
          {
            "text": "[ANK 20190116]",
            "label": "ANK 20190116",
            "url": "https://www.vekn.net/forum/rules-questions/77302-strike-combat-ends-continue-with-the-action#92916"
          }
        ],
        "group": "Action continue as if unblocked"
      },
      {
        "text": "For actions resulting from an action card, \"continue as if unblocked\" moves the action card from the ash heap (where it went when the action was blocked) to limbo (where it should be if the action is not blocked). If the action card is not in the ash heap, then the action cannot be continued. [LSJ 20070808-1]",
        "references": [
          {
            "text": "[LSJ 20070808-1]",
            "label": "LSJ 20070808-1",
            "url": "https://groups.google.com/g/rec.games.trading-cards.jyhad/c/jzMOxZ9oxOs/m/o0X7GUFmii0J"
          }
        ],
        "group": "Action continue as if unblocked"
      }
    ],
    "name": "Foresee",
    "printed_name": "Foresee"
  },
